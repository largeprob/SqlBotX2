    "/login": {
      "get": {
        "tags": [
          "SqlBoTx.Net.ApiService"
        ],
        "operationId": "login",
        "parameters": [
          {
            "name": "account",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "password",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/checkUser": {
      "get": {
