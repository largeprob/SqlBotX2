    "/DatabaseSetting/add": {
      "post": {
        "tags": [
          "数据库连接配置管理"
        ],
        "summary": "新增数据库连接",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/AddDatabaseConnectionDto"
              }
            },
            "application/*+json": {
              "schema": {
                "$ref": "#/components/schemas/AddDatabaseConnectionDto"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "返回受影响的行数",
            "content": {
              "text/plain": {
                "schema": {
                  "pattern": "^-?(?:0|[1-9]\\d*)$",
                  "type": [
                    "integer",
                    "string"
                  ],
                  "format": "int32"
                }
              },
              "application/json": {
                "schema": {
                  "pattern": "^-?(?:0|[1-9]\\d*)$",
                  "type": [
                    "integer",
                    "string"
                  ],
                  "format": "int32"
                }
              },
              "text/json": {
                "schema": {
                  "pattern": "^-?(?:0|[1-9]\\d*)$",
                  "type": [
                    "integer",
                    "string"
                  ],
                  "format": "int32"
                }
              }
            }
          }
        }
      }
    },
    "/DatabaseSetting/update": {
      "post": {
        "tags": [
          "数据库连接配置管理"
