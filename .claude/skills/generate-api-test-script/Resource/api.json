            "thought": "#/components/schemas/BaseContentBlockContentBlockThought",
            "text": "#/components/schemas/BaseContentBlockContentBlockText",
            "sql": "#/components/schemas/BaseContentBlockContentBlockSql",
            "echarts": "#/components/schemas/BaseContentBlockContentBlockEcharts",
